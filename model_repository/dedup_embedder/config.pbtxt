name: "dedup_embedder"
backend: "onnxruntime"
default_model_filename: "dinov3_features.onnx"
max_batch_size: 8

input [
  {
    name: "pixel_values"
    data_type: TYPE_FP32
    dims: [ 3, 384, 384 ]
  }
]

output [
  {
    name: "features"
    data_type: TYPE_FP32
    dims: [ 384 ]
  }
]

instance_group [
  {
    kind: KIND_GPU
    count: 1
    gpus: [ 0 ]
  }
]

dynamic_batching {
  preferred_batch_size: [ 1, 4, 8 ]
  max_queue_delay_microseconds: 5000
}
