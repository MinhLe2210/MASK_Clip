# Copy to .env and fill the required values.

# API / LitServe
HOST=127.0.0.1
PIPELINE_PORT=8002
# API_HOST=127.0.0.1
# API_PORT=8002
LOG_LEVEL=INFO
PIPELINE_BATCH_SIZE=8
PIPELINE_BATCH_TIMEOUT=0.05
LITSERVE_REQUEST_TIMEOUT=180
LITSERVE_MAX_PAYLOAD_SIZE=100MB
LITSERVE_WORKERS_PER_DEVICE=1

# Triton
TRITON_URL=http://127.0.0.1:30000
TRITON_HTTP_PORT=30000
TRITON_GRPC_PORT=30001
TRITON_METRICS_PORT=30002
TRITON_GPU_ID=0

# Dedup embedding model on Triton
DEDUP_MODEL_NAME=dedup_embedder
DEDUP_INPUT_NAME=pixel_values
DEDUP_OUTPUT_NAME=features
DEDUP_IMAGE_SIZE=384
EMBED_DIM=384

# Classification model on Triton
CLASSIFIER_MODEL_NAME=AI_images_detector
CLASSIFIER_INPUT_NAME=pixel_values
CLASSIFIER_OUTPUT_NAME=logits
CLASSIFIER_LABELS=fake,real
CLASSIFIER_INPUT_SIZE=384

# Milvus
COLLECTION_NAME=ai_detector_images_deduplicate
# Use a host reachable from the runtime that executes pipeline_server.py.
# For Docker this is often a service DNS name or host.docker.internal, not 127.0.0.1.
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_DATABASE=default
DUP_THRESHOLD=0.999995
SEARCH_EF=64
MILVUS_RETRIES=5
MILVUS_RETRY_SLEEP=1.0
MILVUS_LOAD_TIMEOUT=120
MILVUS_FLUSH_ON_INSERT=true

# Request limits
MAX_IMAGES_PER_REQUEST=64
REQUEST_TIMEOUT=120
PIPELINE_REQUEST_TIMEOUT=120

# OpenAI
OPENAI_API_KEY=
OPENAI_VLM_MODEL=gpt-5-mini
OPENAI_PROXY=
OPENAI_TIMEOUT=60
OPENAI_VLM_PROMPT=Analyze the image after Triton embedding deduplication and Triton classification. Use the classification result as a signal, but rely on the visual content when explaining the final answer. Return concise JSON with keys: summary, decision, reasons.
