# Copy this file to .env and adjust the required values.
#
# Required for the full pipeline:
# - DEDUP_ENGINE_PATH
# - CLASSIFIER_ENGINE_PATH
# - MILVUS_HOST
# - OPENAI_API_KEY
#
# Notes:
# - Docker Compose reads this file automatically.
# - run_pipeline.sh also auto-loads .env from the repo root.
# - Commented generic vars such as PORT, LITSERVE_*, and MAX_IMAGES_PER_REQUEST
#   are only for running a single service directly. Do not enable conflicting
#   generic values for multiple services in one shared .env unless you know the
#   exact process environment you want.


# Shared runtime settings
LOG_LEVEL=INFO
HOST=127.0.0.1
PYTHON_BIN=python
STARTUP_TIMEOUT=120


# Local ports / endpoints
DEDUP_PORT=8000
CLASSIFIER_PORT=8001
PIPELINE_PORT=8002
DEDUP_API_URL=http://127.0.0.1:8000/dedup
CLASSIFIER_API_URL=http://127.0.0.1:8001/classify


# Required model paths and secrets
MODEL_PATH=
DEDUP_ENGINE_PATH=./engines/images_embeder_dedup.engine
CLASSIFIER_ENGINE_PATH=./engines/classification.engine
OPENAI_API_KEY=
OPENAI_PROXY=


# Dedup service settings
EMBED_DIM=384
DUP_THRESHOLD=0.999995
COLLECTION_NAME=ai_detector_images_deduplicate
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
SEARCH_EF=64
MILVUS_RETRIES=5
MILVUS_RETRY_SLEEP=1.0
MILVUS_LOAD_TIMEOUT=120
MILVUS_FLUSH_ON_INSERT=true


# Classification service settings
CLASSIFIER_LABELS=fake,real
CLASSIFIER_INPUT_NAME=pixel_values
CLASSIFIER_OUTPUT_NAME=output
CLASSIFIER_INPUT_SIZE=384
CLASSIFIER_BATCH_SIZE=16
CLASSIFIER_BATCH_TIMEOUT=0.05


# Pipeline service settings
OPENAI_VLM_MODEL=gpt-5-mini
OPENAI_TIMEOUT=60
PIPELINE_REQUEST_TIMEOUT=60
PIPELINE_BATCH_SIZE=1
PIPELINE_BATCH_TIMEOUT=0.0
OPENAI_VLM_PROMPT=Analyze the image after local deduplication and TensorRT classification. Use the classification result as a signal, but rely on the visual content when explaining the final answer. Return concise JSON with keys: summary, decision, reasons.


# Docker Compose wrapper variables
OPENSDI_IMAGE=opensdi:latest
MODEL_DIR=./models
DEDUP_LITSERVE_ACCELERATOR=gpu
DEDUP_LITSERVE_DEVICES=1
DEDUP_WORKERS_PER_DEVICE=1
DEDUP_BATCH_TIMEOUT=0.05
DEDUP_REQUEST_TIMEOUT=120
DEDUP_MAX_PAYLOAD_SIZE=100MB
DEDUP_MAX_IMAGES_PER_REQUEST=64
CLASSIFIER_MAX_IMAGES_PER_REQUEST=16
CLASSIFIER_LITSERVE_ACCELERATOR=gpu
CLASSIFIER_LITSERVE_DEVICES=1
CLASSIFIER_WORKERS_PER_DEVICE=1
CLASSIFIER_REQUEST_TIMEOUT=120
PIPELINE_WORKERS_PER_DEVICE=1
PIPELINE_LITSERVE_REQUEST_TIMEOUT=180


# ONNX -> TensorRT conversion script settings
TRT_DOCKER_IMAGE=
TRTEXEC_BIN=trtexec
INPUT_NAME=pixel_values
MIN_SHAPE=1x3x224x224
OPT_SHAPE=1x3x224x224
MAX_SHAPE=8x3x224x224
PRECISION=fp16
WORKSPACE_MB=4096
SKIP_SHAPES=0
EXTRA_TRTEXEC_ARGS=


# Disclosed external / legacy names not consumed by the current codebase
# These are kept as comments for reference only.
# API_HOST=127.0.0.1
# API_PORT=30004
# DATABASE=default
# MILVUS_DATABASE=default
# BATCH_SIZE=64
# DEDUP_HOST=127.0.0.1


# Optional direct-service overrides for `python main.py`
# PORT=8000
# MAX_IMAGES_PER_REQUEST=64
# LITSERVE_ACCELERATOR=auto
# LITSERVE_DEVICES=auto
# LITSERVE_WORKERS_PER_DEVICE=1
# LITSERVE_REQUEST_TIMEOUT=120
# LITSERVE_MAX_BATCH_SIZE=8
# LITSERVE_BATCH_TIMEOUT=0.05
# LITSERVE_MAX_PAYLOAD_SIZE=100MB


# Optional direct-service overrides for `python classification_server.py`
# PORT=8001
# CLASSIFIER_PORT=8001
# MAX_IMAGES_PER_REQUEST=16
# LITSERVE_ACCELERATOR=auto
# LITSERVE_DEVICES=auto
# LITSERVE_WORKERS_PER_DEVICE=1
# LITSERVE_REQUEST_TIMEOUT=120


# Optional direct-service overrides for `python pipeline_server.py`
# PORT=8002
# PIPELINE_PORT=8002
# LITSERVE_ACCELERATOR=cpu
# LITSERVE_DEVICES=1
# LITSERVE_WORKERS_PER_DEVICE=1
# LITSERVE_REQUEST_TIMEOUT=180
