# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/

# Test, lint, and local tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.coverage
.coverage.*
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Environment and local-only config
.env
.env.*
!.env.example

# Model and inference artifacts
models/
*.onnx
*.onnx.data
*.engine
*.plan

# Keep Triton repo config in git, but ignore model weights/artifacts.
model_repository/*
!model_repository/*/
model_repository/*/*
!model_repository/*/config.pbtxt
!model_repository/*/1/
model_repository/*/1/*
!model_repository/*/1/.gitkeep

# Logs and runtime output
*.log

